SELECT  u.Name, cf.Semester , sc.NAME as SectionName, c.Title as CourseTitle FROM section  sc
JOIN student st on sc.ID = st.Section
JOIN users u on u.ID = st.userID
JOIN CourseEnrollment ce on ce.StudentID = st.StudentID
JOIN CourseOffering cf on cf.ID = ce.OfferingID
JOIN CourseAllocation ca on ca.OfferingID = cf.ID
JOIN Course c on c.ID = cf.CourseID
WHERE ce.status = 'enrolled' 
and ca.[status] = 'allocated'

